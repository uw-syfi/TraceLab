.venv/
.uv-cache/
__pycache__/
*.py[cod]
*.tex

trace/*.jsonl
trace/*.jsonl.gz
trace/*.json
trace/*.csv
trace/*.duckdb

# artifacts/: track experiment code (*.py) and README.md only; everything else
# under artifacts/ is a generated output and stays ignored. Each experiment lives
# in artifacts/<category>/<experiment>/ and writes its PNG/CSV/JSON/MD reports
# next to its script.
artifacts/**/*.png
artifacts/**/*.csv
artifacts/**/*.json
artifacts/**/*.jsonl
artifacts/**/*.svg
artifacts/**/*.pdf
artifacts/**/*.md
!artifacts/**/README.md
# README.zh.md are hand-written Chinese translations of the write-ups (source content, same as
# README.md — not a generated report), so keep them tracked too.
!artifacts/**/README.zh.md
# pricing.json is hand-maintained config (the single price source), not a generated report
!artifacts/utils/pricing.json
# hand-written schema reference (not a generated report), so keep it tracked:
!artifacts/utils/DB_SCHEMA.md

summary.before_*.json
copy_from_other.sh
!trace/README.md
!artifacts/README.md

# validators/: track validator code (*.py) and README.md only; generated CSV/JSON/MD
# reports stay ignored next to the validator that produced them.
validators/**/*.png
validators/**/*.csv
validators/**/*.json
validators/**/*.jsonl
validators/**/*.svg
validators/**/*.pdf
validators/**/*.md
!validators/**/README.md

# Contribute sidecar runtime pool (uploads + index + snapshot)
web/server/data/
.runtime/

# Scratch screenshots, local test fixtures, and scratch design demos (not part of the build)
/image*.png
/test_workload_*.tar.gz
/trace.tar.gz
web/app/*-preview.html
# Paper PDF hosted by the static site: shipped via rsync from dist/, kept out of git (large binary).
web/app/public/paper.pdf
# Local scratch workspace (unrelated infra / paper sources), never part of the build
/temp/

# Local-only deployment routine for UW CSE production host.
.codex/skills/tracelab-send-to-production/
# Local-only runbook: self-hosted vLLM on ptc GPU 1 + AI-backend wiring (names internal hosts/keys).
.codex/skills/serve-vllm-ptc/
/blog/