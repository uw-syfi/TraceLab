# Node / Astro
app/node_modules/
app/dist/
app/.astro/
app/.vite/
npm-debug.log*

# Derived web assets (regenerated by web/scripts/build-payload.mjs + the toolkit render).
# Never commit trace-derived data or the Pyodide payload copies.
app/public/data/
app/public/figures/
app/public/py/
app/public/pyodide/
# Self-hosted webfonts (霞鹜文楷 shards + Fraunces/Hanken), copied from npm deps by
# web/scripts/build-fonts.mjs on prebuild, plus the generated @font-face CSS it emits into src/.
app/public/fonts/
app/src/styles/*.generated.css
app/src/styles/font-preload.json

# Runtime logs (contain client IPs / user questions) — never commit.
server/data/audit/
server/data/metrics/
ai_infra/logs/
