---
import '../styles/index.css';
// Preload list (Latin core blocks + the CJK static subset) generated by web/scripts/build-fonts.mjs.
// These are the fonts first paint needs; preloading them avoids a flash-of-unstyled-text swap.
import fontPreload from '../styles/font-preload.json';
import Topbar from '../components/Topbar.astro';
import AskTrace from '../components/AskTrace.astro';
import { localeFromUrl, useTranslations } from '../i18n';

interface Props {
  title?: string;
  description?: string;
}
const locale = localeFromUrl(Astro.url);
const copy = useTranslations(Astro.url);
const { title = copy.meta.title, description = copy.meta.description } = Astro.props;
const pageUrl = new URL(Astro.url.pathname, 'https://tracelab.cs.washington.edu').toString();
const isHomeLike = Astro.url.pathname === '/' || Astro.url.pathname === '/zh/';
const browserCopy = copy.browser;
---

<!doctype html>
<html lang={locale === 'zh' ? 'zh-CN' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="google-site-verification" content="MNhYIiKaE8kbPjpTZZ9SN80ljHJnvLfiWyO-kh_PNqs" />
    {/* Set the theme before first paint to avoid a flash: an explicit saved choice wins, otherwise
        default to dark (ignoring the OS preference). */}
    <script is:inline>
      (() => {
        try {
          const saved = localStorage.getItem('theme');
          const dark = saved ? saved === 'dark' : true;
          if (dark) document.documentElement.dataset.theme = 'dark';
        } catch (_) {}
      })();
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={pageUrl} />
    {isHomeLike && (
      <>
        <link rel="alternate" hreflang="en" href="https://tracelab.cs.washington.edu/" />
        <link rel="alternate" hreflang="zh-CN" href="https://tracelab.cs.washington.edu/zh/" />
        <link rel="alternate" hreflang="x-default" href="https://tracelab.cs.washington.edu/" />
      </>
    )}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="SyFI TraceLab" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" href="/syfi-favicon.svg" type="image/svg+xml" />
    <script is:inline>
      (() => {
        const isIndex = location.pathname === '/' || location.pathname === '/zh/' || location.pathname.endsWith('/index.html');
        const initial = location.hash.slice(1);
        if (isIndex && ['compare', 'analyze', 'pool'].includes(initial)) {
          document.documentElement.dataset.initialSurface = initial;
        }
      })();
    </script>
    {/* All webfonts (Fraunces + Hanken Grotesk + 霞鹜文楷) are self-hosted via src/styles/*.generated.css
        (@import-ed in index.css; see web/scripts/build-fonts.mjs) — no external font CDN, works offline.
        Preload the first-paint fonts (Latin core + CJK static subset) so static text shows without a swap flash. */}
    {fontPreload.map((href) => (
      <link rel="preload" href={href} as="font" type="font/woff2" crossorigin />
    ))}
    <script is:inline define:vars={{ browserCopy }}>
      window.__TRACELAB_I18N__ = browserCopy;
    </script>
  </head>
  <body>
    <div class="blobs" aria-hidden="true">
      <span class="blob b1"></span>
      <span class="blob b2"></span>
      <span class="blob b3"></span>
    </div>

    <Topbar />
    <AskTrace />

    <div class="shell">
      <slot />
    </div>

    {/* Register the Pyodide-cache service worker (see public/sw.js): downloads the ~40 MB runtime +
        packages once, then serves them from the Cache API on every later boot/visit. */}
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {});
        });
      }
    </script>

    {/* Pageview beacon — access counts + top pages (no dwell time). The compare/analyze/pool
        surfaces are hash views on '/', switched via the 'surface:show' event (Topbar), so we beacon
        those too. Fire-and-forget same-origin POST to the contribute sidecar through the /api proxy. */}
    <script is:inline>
      (() => {
        const send = (surface) => {
          try {
            const body = JSON.stringify({
              path: location.pathname,
              hash: surface || location.hash.replace('#', ''),
              ref: document.referrer,
            });
            if (navigator.sendBeacon) {
              navigator.sendBeacon('/api/metrics', new Blob([body], { type: 'application/json' }));
            } else {
              fetch('/api/metrics', {
                method: 'POST',
                body,
                keepalive: true,
                headers: { 'Content-Type': 'application/json' },
              }).catch(() => {});
            }
          } catch (_) {}
        };
        send();
        document.addEventListener('surface:show', (e) => send(e && e.detail));
      })();
    </script>
  </body>
</html>
