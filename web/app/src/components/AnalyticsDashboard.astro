---
// Interactive analytics dashboard skeleton — the shared DOM + styles behind the /lab sandbox and the
// Analyze surface. A host renders this, then drives it via lib/analytics/dashboard.ts
// (initDashboard() once, loadDashboard(payload, source) per trace). Carries no data of its own.
---

<div class="analytics" id="analytics-dashboard">
  <!-- KPI row -->
  <div class="kpi-grid" id="kpis">
    <div class="kpi acc-sage"><div class="label">Sessions</div><div class="num" data-kpi="sessions">—</div><div class="foot" data-foot="span">—</div></div>
    <div class="kpi acc-sage"><div class="label">Agent steps</div><div class="num" data-kpi="rounds">—</div><div class="foot" data-foot="users">—</div></div>
    <div class="kpi feature"><div class="label">Total cost</div><div class="num" data-kpi="cost">—</div><div class="foot" data-foot="costperday">—</div></div>
    <div class="kpi acc-gold"><div class="label">Cache saved</div><div class="num" data-kpi="saved">—</div><div class="foot">vs. all-fresh billing</div></div>
    <div class="kpi acc-sage"><div class="label">Total input</div><div class="num" data-kpi="input">—</div><div class="foot" data-foot="cachedpct">—</div></div>
    <div class="kpi acc-gold"><div class="label">Cached input</div><div class="num" data-kpi="cached">—</div><div class="foot">prefix served from cache</div></div>
    <div class="kpi acc-terra"><div class="label">Uncached input</div><div class="num" data-kpi="uncached">—</div><div class="foot">fresh input tokens</div></div>
    <div class="kpi acc-sage"><div class="label">Total output</div><div class="num" data-kpi="output">—</div><div class="foot" data-foot="outputperstep">—</div></div>
  </div>

  <!-- Providers split (one divided line) -->
  <div class="sec-head"><h2>Providers</h2><span class="sub">How your agent steps and spend divide across providers.</span></div>
  <div class="panel prov-panel">
    <div class="prov-bar" id="prov-bar"></div>
    <div class="prov-legend" id="prov-legend"></div>
  </div>

  <!-- Daily activity (own row) -->
  <div class="sec-head"><h2>Activity</h2><span class="sub">Per-day steps and when you tend to work (local time).</span></div>
  <div class="panel"><h3>Daily activity</h3><p class="desc">Steps per day across the trace.</p><div class="chart chart--calendar" id="c-calendar"></div></div>
  <!-- Work rhythm (own row) -->
  <div class="panel" style="margin-top:20px;"><h3>Work rhythm</h3><p class="desc">Hour of day × weekday — darker means more agent steps in that slot.</p><div class="chart chart--heat" id="c-heat"></div></div>

  <!-- Cost -->
  <div class="sec-head"><h2>Cost</h2><span class="sub">By model, split into cached-read · fresh-input · output.</span></div>
  <div class="panel"><h3>Spend by model</h3><p class="desc" id="cost-asof">—</p><div class="chart chart--cost" id="c-cost"></div></div>

  <!-- Facts (grouped into categories by JS) -->
  <div class="sec-head"><h2>Highlights</h2><span class="sub">Superlatives from your trace. Click one to jump to its session.</span></div>
  <div id="facts"></div>

  <!-- Sessions -->
  <div class="sec-head"><h2>Sessions</h2><span class="sub">Filter, then pick a session to replay its token timeline.</span></div>
  <div class="sess-toolbar">
    <div class="seg" id="sess-provider" role="group" aria-label="Filter by provider">
      <button class="active" data-prov="all">All</button>
      <button data-prov="claude">Claude</button>
      <button data-prov="codex">Codex</button>
    </div>
    <label class="field"><span>Sort</span>
      <select id="sess-sort">
        <option value="rounds">Most steps</option>
        <option value="duration">Longest</option>
        <option value="cost">Most expensive</option>
        <option value="recent">Most recent</option>
      </select>
    </label>
    <input class="sess-search" id="sess-search" type="search" placeholder="Search session…" aria-label="Search sessions" />
    <span class="sess-count" id="sess-count"></span>
  </div>
  <div class="sess-layout">
    <div class="sess-list" id="sess-list" role="listbox" aria-label="Sessions"></div>
    <div class="panel sess-detail">
      <h3 id="sess-title">—</h3>
      <p class="desc" id="sess-meta">—</p>
      <div class="chart chart--session" id="c-session"></div>
      <div class="round-detail" id="round-detail"></div>
      <div class="sess-tools" id="sess-tools"></div>
    </div>
  </div>

  <!-- Aggregate stats -->
  <div class="sec-head"><h2>Stats</h2><span class="sub">Averages, percentiles &amp; rates across the trace.</span></div>
  <div class="stats-grid" id="stats"></div>

  <!-- Distributions -->
  <div class="sec-head"><h2>Distributions</h2><span class="sub">The classic figures, now interactive (hover, zoom, export PNG).</span></div>
  <div class="dist-grid" id="dist"></div>
</div>

<!-- is:global because the facts / session list / distribution cards are created at runtime via
     document.createElement — Astro's scoped styles only match server-rendered template elements, so
     scoped rules never reach them. Selectors are either scoped under `.analytics` or use the
     dashboard's own unique class names, so they don't leak into other surfaces. -->
<style is:global>
  .analytics .chart { width: 100%; }
  .analytics .chart--calendar { height: 250px; }
  .analytics .chart--heat { height: 250px; }
  .analytics .chart--cost { height: 320px; }
  .analytics .chart--session { height: 576px; }
  .analytics .chart--dist { height: 320px; }

  /* chart panels carry their own internal margins — trim the panel padding so they don't double up */
  .analytics .panel:has(.chart) { padding: 20px 24px 14px; }
  .analytics .panel:has(.chart) .desc { margin-bottom: 10px; }

  /* providers — one divided line, each segment sized to a provider's step share */
  .prov-panel { padding: 22px 24px 20px; }
  .prov-bar { display: flex; width: 100%; height: 48px; gap: 3px; border-radius: var(--r-sm); overflow: hidden; }
  .prov-seg { display: flex; align-items: center; justify-content: space-between; gap: 10px; min-width: 0; padding: 0 14px; color: #fff; text-shadow: 0 1px 2px rgba(0,0,0,.22); white-space: nowrap; overflow: hidden; transition: filter .25s var(--ease); }
  .prov-seg:hover { filter: brightness(1.07); }
  .prov-seg .pl { font-weight: 650; font-size: var(--fs-sm); text-transform: capitalize; overflow: hidden; text-overflow: ellipsis; }
  .prov-seg .pct { font-weight: 700; font-size: var(--fs-sm); font-variant-numeric: tabular-nums; flex: none; }
  .prov-legend { display: flex; flex-wrap: wrap; gap: 14px 28px; margin-top: 16px; }
  .prov-item { display: flex; align-items: baseline; gap: 9px; }
  .prov-dot { width: 12px; height: 12px; border-radius: 3px; flex: none; transform: translateY(1px); }
  .prov-item .pn { font-weight: 600; color: var(--ink); font-size: var(--fs-sm); text-transform: capitalize; }
  .prov-item .pm { color: var(--muted); font-size: var(--fs-xs); font-variant-numeric: tabular-nums; }

  /* highlights grouped into categories */
  #facts { margin-top: 18px; display: flex; flex-direction: column; gap: 32px; }
  .fact-cat-head { display: flex; align-items: baseline; gap: 14px; margin-bottom: 16px; }
  .fact-cat-label { font-family: var(--serif); font-weight: 560; font-size: var(--fs-xl); color: var(--ink); white-space: nowrap; letter-spacing: -.2px; }
  .fact-cat-count { font-size: var(--fs-xs); color: var(--muted); font-variant-numeric: tabular-nums; }
  .fact-cat-rule { flex: 1; height: 1px; background: var(--line); }

  /* facts — "ledger plates" echoing the KPI cards: accent rail, corner bloom, big numeral, serif title */
  .facts-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(290px, 1fr)); gap: 16px; }
  .fact {
    --acc: var(--terra); --acc-wash: var(--terra-wash);
    position: relative; overflow: hidden; isolation: isolate;
    display: flex; flex-direction: column; text-align: left;
    background: linear-gradient(180deg, var(--card) 0%, var(--card-2) 100%);
    border: 1px solid var(--line); border-radius: var(--r-md);
    padding: 22px 24px 22px 26px; box-shadow: var(--sh-1);
    font-family: var(--sans); color: var(--ink); cursor: default;
    transition: transform .45s var(--ease), box-shadow .45s var(--ease), border-color .45s var(--ease);
  }
  /* left accent rail */
  .fact::before {
    content: ""; position: absolute; left: 0; top: 18px; bottom: 18px; width: 3px;
    border-radius: 0 3px 3px 0; background: var(--acc); opacity: .85; z-index: 0;
    transition: top .45s var(--ease), bottom .45s var(--ease), opacity .45s var(--ease);
  }
  /* soft corner bloom */
  .fact::after {
    content: ""; position: absolute; right: -48px; top: -48px; width: 150px; height: 150px;
    background: radial-gradient(circle at 58% 42%, var(--acc-wash), transparent 68%);
    opacity: .5; pointer-events: none; z-index: 0;
    transition: opacity .5s var(--ease), transform .55s var(--ease);
  }
  .fact > * { position: relative; z-index: 1; }
  .fact[data-link="1"] { cursor: pointer; }
  .fact[data-link="1"]:hover { transform: translateY(-5px); box-shadow: var(--sh-2); border-color: color-mix(in srgb, var(--acc) 45%, var(--line)); }
  .fact[data-link="1"]:hover::before { top: 12px; bottom: 12px; opacity: 1; }
  .fact[data-link="1"]:hover::after { opacity: .9; transform: scale(1.14) translate(-4px, 4px); }

  .fact .fact-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; min-height: 20px; }
  .fact .fact-chip {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: var(--fs-2xs); letter-spacing: .12em; text-transform: uppercase; font-weight: 700; color: var(--acc);
  }
  .fact .fact-chip::before {
    content: ""; width: 7px; height: 7px; border-radius: 50%; flex: none;
    background: var(--acc); box-shadow: 0 0 0 3px var(--acc-wash);
  }
  .fact .fact-go { font-size: var(--fs-lg); line-height: 1; color: var(--acc); opacity: 0; transform: translateX(-5px); transition: opacity .3s var(--ease), transform .3s var(--ease); }
  .fact[data-link="1"]:hover .fact-go { opacity: 1; transform: translateX(0); }

  /* caption first (what it is), then the big number — easier to read than a number with no label.
     Reserve a fixed 2-line height (and clamp to 2) so the numbers align across a row regardless of
     whether a caption wraps to one line or two. */
  .fact .fact-title {
    font-family: var(--serif); font-weight: 560; font-size: var(--fs-md); line-height: 1.2; color: var(--ink);
    display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; line-clamp: 2;
    overflow: hidden; min-height: 2.4em;
  }
  .fact .fact-val {
    font-weight: 700; font-variant-numeric: tabular-nums; font-feature-settings: "tnum" 1;
    font-size: var(--fs-2xl); line-height: 1.0; letter-spacing: -1px; color: var(--ink); margin-top: 16px;
  }
  .fact .fact-detail { font-size: var(--fs-sm); color: var(--muted); margin-top: 8px; line-height: 1.45; }

  /* per-dimension accent — clusters of color since facts are grouped by dimension */
  .fact[data-dim="time"], .fact[data-dim="reasoning"] { --acc: var(--terra); --acc-wash: var(--terra-wash); }
  .fact[data-dim="session"], .fact[data-dim="tool"], .fact[data-dim="model"] { --acc: var(--sage); --acc-wash: var(--sage-wash); }
  .fact[data-dim="cost"], .fact[data-dim="cache"] { --acc: var(--gold); --acc-wash: color-mix(in srgb, var(--gold) 22%, transparent); }

  /* session filter toolbar */
  .sess-toolbar { display: flex; align-items: center; gap: 14px; margin-top: 18px; flex-wrap: wrap; }
  .seg { display: inline-flex; gap: 4px; background: color-mix(in srgb, var(--card) 60%, transparent); padding: 4px; border-radius: 999px; border: 1px solid var(--line); }
  .seg button {
    font-family: var(--sans); font-size: var(--fs-xs); font-weight: 500; color: var(--muted);
    border: none; background: transparent; padding: 7px 16px; border-radius: 999px; cursor: pointer;
    transition: color .25s var(--ease), background .25s var(--ease), box-shadow .25s var(--ease);
  }
  .seg button:hover { color: var(--ink); }
  .seg button.active { color: var(--ink); background: var(--card); box-shadow: var(--sh-1); font-weight: 600; }
  .sess-toolbar .field { display: inline-flex; align-items: center; gap: 8px; font-size: var(--fs-xs); color: var(--muted); }
  .sess-toolbar select, .sess-search {
    font-family: var(--sans); font-size: var(--fs-xs); color: var(--ink);
    background: var(--card); border: 1px solid var(--line); border-radius: var(--r-sm); padding: 8px 12px;
    transition: border-color .25s var(--ease);
  }
  .sess-toolbar select:hover, .sess-search:hover { border-color: var(--sage-soft); }
  .sess-toolbar select:focus-visible, .sess-search:focus-visible { outline: 2px solid var(--terra); outline-offset: 1px; }
  .sess-search { min-width: 200px; }
  .sess-count { margin-left: auto; font-size: var(--fs-xs); color: var(--muted); font-variant-numeric: tabular-nums; }
  .sess-empty { color: var(--muted); font-size: var(--fs-sm); padding: 16px 4px; }

  /* sessions stacked as full-width rows: the date-grouped picker (its own scroll block), then the
     detail below. Each day = a narrow 2-line date marker with its sessions flowing to the right,
     wrapping to the next line when they don't fit. */
  .sess-layout { display: flex; flex-direction: column; gap: 20px; margin-top: 16px; }
  .sess-list { display: flex; flex-direction: column; gap: 16px; max-height: 360px; overflow-y: auto; border: 1px solid var(--line); border-radius: var(--r-md); background: color-mix(in srgb, var(--card-2) 55%, transparent); padding: 16px 18px; }
  /* [ date column ] •| [ session cards ] — a full-height divider sits between the date and its
     sessions, with a terra node on it aligned to the date. The muted count fills the old empty space. */
  .sess-date-group { display: flex; align-items: stretch; gap: 0; }
  .sess-date-head { position: relative; flex: none; width: 90px; display: flex; flex-direction: column; line-height: 1.15; padding: 1px 18px 4px 2px; border-right: 1px solid var(--line); }
  .sess-date-head::after { content: ""; position: absolute; right: -4.5px; top: 5px; width: 9px; height: 9px; border-radius: 50%; background: var(--terra); }
  .sess-date-head .sd-wd { font-size: var(--fs-2xs); text-transform: uppercase; letter-spacing: .06em; color: var(--muted); font-weight: 700; }
  .sess-date-head .sd-md { font-family: var(--serif); font-weight: 560; font-size: var(--fs-md); color: var(--ink); margin-top: 1px; }
  .sess-date-head .sd-count { margin-top: 8px; font-size: var(--fs-2xs); color: var(--muted); white-space: nowrap; }
  .sess-cards { flex: 1; min-width: 0; display: flex; flex-wrap: wrap; gap: 10px; padding-left: 18px; }
  .sess-row {
    flex: 0 1 210px; max-width: 250px;
    text-align: left; cursor: pointer; background: var(--card); border: 1px solid var(--line);
    border-radius: var(--r-sm); padding: 12px 14px; transition: border-color .25s var(--ease), background .25s var(--ease), transform .25s var(--ease);
  }
  .sess-row:hover { transform: translateY(-2px); border-color: var(--sage-soft); }
  .sess-row.active { border-color: var(--terra); background: var(--card-2); }
  .sess-row .sr-id { font-weight: 600; font-size: var(--fs-sm); color: var(--ink); display: flex; align-items: flex-start; gap: 8px; }
  /* title may wrap to two lines before clamping, so more of it is readable in the narrow card */
  .sess-row .sr-name { flex: 1; min-width: 0; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; line-clamp: 2; overflow: hidden; line-height: 1.25; }
  .sess-row .sr-meta { font-size: var(--fs-xs); color: var(--muted); margin-top: 4px; white-space: nowrap; }
  .sess-row .pill { flex: none; font-size: var(--fs-2xs); padding: 2px 8px; border-radius: 999px; background: var(--terra-wash); color: var(--on-terra); font-weight: 600; }
  .sess-row .pill.codex { background: var(--sage-wash); color: var(--on-sage); }
  .sess-detail { display: flex; flex-direction: column; }

  /* per-round inspector (click a round in the timeline) */
  .round-detail { margin-top: 14px; }
  .round-detail .rd-hint { color: var(--muted); font-size: var(--fs-sm); padding: 10px 2px; }
  .round-detail .rd-card { border: 1px solid var(--line); border-radius: var(--r-md); background: color-mix(in srgb, var(--card-2) 55%, transparent); padding: 16px 18px; }
  .round-detail .rd-head { display: flex; align-items: baseline; gap: 12px; flex-wrap: wrap; margin-bottom: 14px; }
  .round-detail .rd-seq { font-family: var(--serif); font-weight: 560; font-size: var(--fs-lg); color: var(--ink); }
  .round-detail .rd-tag { font-size: var(--fs-2xs); text-transform: uppercase; letter-spacing: .06em; font-weight: 700; padding: 3px 10px; border-radius: 999px; }
  .round-detail .rd-tag.user { color: var(--on-terra); background: var(--terra-wash); }
  .round-detail .rd-tag.tool { color: var(--on-sage); background: var(--sage-wash); }
  .round-detail .rd-time { font-size: var(--fs-xs); color: var(--muted); font-variant-numeric: tabular-nums; margin-left: auto; }
  .round-detail .rd-stats { display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 12px 18px; }
  .round-detail .rd-stat { display: flex; flex-direction: column; gap: 2px; }
  .round-detail .rd-stat span { font-size: var(--fs-xs); color: var(--muted); }
  .round-detail .rd-stat b { font-size: var(--fs-md); color: var(--ink); font-weight: 650; font-variant-numeric: tabular-nums; }
  .round-detail .rd-tools { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 14px; padding-top: 14px; border-top: 1px solid var(--line); }
  .round-detail .rd-tool { font-size: var(--fs-xs); color: var(--ink); background: var(--card); border: 1px solid var(--line); border-radius: 999px; padding: 5px 12px; }
  .round-detail .rd-tool b { color: var(--muted); font-weight: 500; }
  .round-detail .rd-tool.err { border-color: color-mix(in srgb, var(--terra) 50%, var(--line)); color: var(--terra); }
  .round-detail .rd-tools .rd-empty { font-size: var(--fs-sm); color: var(--muted); }
  /* raw input/output viewer — one independently-collapsible <details> row per section (only when the
     trace carries raw text). Output defaults open; Input/Tools default folded. */
  .round-detail .rd-raw { margin-top: 14px; padding-top: 14px; border-top: 1px solid var(--line); display: flex; flex-direction: column; gap: 8px; }
  .round-detail .raw-sec { border: 1px solid var(--line); border-radius: var(--r-sm); background: color-mix(in srgb, var(--card-2) 40%, transparent); overflow: hidden; }
  .round-detail .raw-sec > summary { cursor: pointer; list-style: none; display: flex; align-items: center; gap: 9px; padding: 9px 13px; font-size: var(--fs-2xs); text-transform: uppercase; letter-spacing: .06em; font-weight: 700; color: var(--muted); user-select: none; }
  .round-detail .raw-sec > summary::-webkit-details-marker { display: none; }
  .round-detail .raw-sec > summary::before { content: "▸"; font-size: var(--fs-2xs); color: var(--muted); transition: transform .15s var(--ease); }
  .round-detail .raw-sec[open] > summary { color: var(--ink); border-bottom: 1px solid var(--line); }
  .round-detail .raw-sec[open] > summary::before { transform: rotate(90deg); }
  .round-detail .raw-pre { margin: 0; max-height: 260px; overflow: auto; font-family: var(--mono, ui-monospace, monospace); font-size: var(--fs-xs); line-height: 1.5; color: var(--ink); background: var(--card); padding: 12px 14px; white-space: pre-wrap; word-break: break-word; }
  .round-detail .raw-pre.sm { max-height: 170px; font-size: var(--fs-2xs); }
  .round-detail .raw-pre.res { color: var(--muted); border-top: 1px dashed var(--line); }
  .round-detail .raw-tools { display: flex; flex-direction: column; gap: 12px; padding: 12px 14px; }
  .round-detail .raw-tool { border-left: 2px solid var(--line); padding-left: 12px; display: flex; flex-direction: column; gap: 6px; }
  .round-detail .raw-tool .raw-pre { border: 1px solid var(--line); border-radius: var(--r-sm); }
  .round-detail .raw-tool .raw-pre.res { border-top: 1px dashed var(--line); }
  .round-detail .raw-tool-h { font-size: var(--fs-xs); font-weight: 650; color: var(--ink); }
  .round-detail .raw-tool.err { border-left-color: var(--terra); }
  .round-detail .raw-tool.err .raw-tool-h { color: var(--terra); }
  .sess-tools { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 14px; }
  .sess-tools .tool { font-size: var(--fs-xs); color: var(--muted); background: var(--card-2); border: 1px solid var(--line); border-radius: 999px; padding: 5px 12px; }
  .sess-tools .tool b { color: var(--ink); font-variant-numeric: tabular-nums; }

  /* aggregate stats — JS greedy bin-pack into balanced columns (tallest card → shortest column)
     so no column runs long. .stat-col is one column; cards keep logical order within a column. */
  .stats-grid { display: flex; gap: 16px; align-items: flex-start; margin-top: 20px; }
  .stat-col { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 16px; }
  .stat-group { background: var(--card); border: 1px solid var(--line); border-radius: var(--r-lg); padding: 18px 22px 12px; box-shadow: var(--sh-1); }
  .stat-group h4 { font-family: var(--serif); font-weight: 540; font-size: var(--fs-xl); margin: 0 0 6px; display: flex; align-items: baseline; gap: 10px; }
  .stat-group h4 .gcount { font-family: var(--sans); font-size: var(--fs-xs); color: var(--muted); font-variant-numeric: tabular-nums; }
  /* subsection divider inside a card — terra pill anchored at the content edge (aligned with the
     card title); its 12px inset puts the label text right over the indented rows below. */
  .stat-sub { display: flex; align-items: center; gap: 10px; margin: 22px 0 6px; }
  .stat-sub:first-of-type { margin-top: 10px; }
  .stat-sub .ssl { font-size: var(--fs-sm); letter-spacing: .06em; text-transform: uppercase; font-weight: 700; color: var(--on-terra); background: var(--terra-wash); padding: 3px 12px; border-radius: 999px; white-space: nowrap; }
  .stat-sub .ssr { flex: 1; height: 1px; background: var(--line); }
  /* rows hang slightly indented under their subsection label (which stays at the content edge) */
  .stat-row { display: flex; align-items: baseline; justify-content: space-between; gap: 18px; padding: 10px 0 10px 12px; border-top: 1px solid var(--line); }
  .stat-row:first-of-type, .stat-sub + .stat-row { border-top: none; }
  .stat-row .sk { font-size: var(--fs-md); color: color-mix(in srgb, var(--ink) 74%, var(--muted)); font-weight: 500; line-height: 1.35; }
