---
import { loadSummary } from '../../lib/summary';
import { intComma, magnitude, pct, pct1, fmtRange } from '../../lib/format';
import { gallerySectionKey, overviewFigureSections, type StatKey } from '../../lib/figures';
import { headlinesFor } from '../../lib/headlines';
import KpiGrid from '../KpiGrid.astro';
import Kpi from '../Kpi.astro';
import Band from '../Band.astro';
import Panel from '../Panel.astro';
import ProviderDonut from '../ProviderDonut.astro';
import GalleryCard from '../GalleryCard.astro';
import ProjectLinks from '../ProjectLinks.astro';
import Footer from '../Footer.astro';
import { localeFromUrl, useTranslations } from '../../i18n';

const locale = localeFromUrl(Astro.url);
const t = useTranslations(Astro.url);
const o = t.overview;
const fcopy = t.figures;

const s = loadSummary();
const m = s.merged;
const inp = m.tokens.input;

const rounds = m.scope.llm_rounds_total;
const totalInput = magnitude(inp.total_input_tokens);
const cached = magnitude(inp.cached_read_input_tokens);
const newIn = magnitude(inp.new_input_tokens);
const totalOutput = magnitude(m.tokens.output.total_output_tokens_including_reasoning);
const cachedShare = pct(inp.cached_read_input_tokens / inp.total_input_tokens);

const rbp = m.rounds_by_provider;
const claude = rbp.claude ?? 0;
const codex = rbp.codex ?? 0;

const g = inp.total_input_growth_when_started_with_tool_result;
const statMap: Record<StatKey, { label: string; value: string }[]> = {
  input_growth: [
    { label: o.statLabels.grew, value: pct1(g.positive_growth_share) },
    { label: o.statLabels.shrank, value: pct1(g.negative_growth_share) },
    { label: o.statLabels.avgGrowth, value: `${intComma(g.average_positive_growth_tokens)} tok` },
  ],
};

const range = fmtRange(m.scope.earliest_observed_timestamp, m.scope.latest_observed_timestamp);
let galleryCardIndex = 0;
const nextGalleryDelay = () => 420 + galleryCardIndex++ * 40;
const localizedSection = (section: (typeof overviewFigureSections)[number]) =>
  fcopy.sections[section.key as keyof typeof fcopy.sections] ?? section;
const localizedCard = (title: string, blurb: string) => fcopy.cards[title] ?? { title, blurb };
---

<section class="surface live" id="overview" role="tabpanel" aria-label={o.aria}>
  <div class="overview-top">
    <div class="hero reveal" style="--d:60ms">
      <span class="eyebrow">{o.eyebrow}</span>
      <h1>SyFI <em>TraceLab</em></h1>
      <p class="lede">
        {o.lede[0]}
        <br />
        {o.lede[1]}
      </p>
      <ProjectLinks variant="strip" class="hero-links reveal" style="--d:240ms" />
    </div>

    <div class="snapshot-col">
      <div class="sec-head reveal" style="--d:150ms">
        <h2>{o.snapshot}</h2>
      </div>

      <KpiGrid delay={200}>
        <Kpi label={o.kpis.users} value={intComma(m.scope.distinct_users)} accent="sage" />
        <Kpi label={o.kpis.sessions} value={intComma(m.scope.total_sessions)} accent="sage" />
        <Kpi label={o.kpis.steps} value={intComma(rounds)} accent="gold" />
        {/* foot hidden for now — restore: <Kpi label={o.kpis.steps} value={intComma(rounds)} foot={o.kpis.stepsFoot} accent="gold" /> */}
        <Kpi label={o.kpis.tools} value={intComma(m.tools.total_tool_calls)} accent="sage" />
      </KpiGrid>

      <KpiGrid delay={260} mt>
        <Kpi label={o.kpis.input} value={totalInput.num} unit={totalInput.unit} feature />
        <Kpi label={o.kpis.cached} value={cached.num} unit={cached.unit} accent="terra" />
        {/* foot hidden for now — restore: <Kpi label={o.kpis.cached} value={cached.num} unit={cached.unit} foot={`${cachedShare}% ${o.kpis.cachedFoot}`} accent="terra" /> */}
        <Kpi label={o.kpis.append} value={newIn.num} unit={newIn.unit} accent="terra" />
        <Kpi label={o.kpis.output} value={totalOutput.num} unit={totalOutput.unit} accent="terra" />
      </KpiGrid>
    </div>
  </div>

  <Band delay={360}>
    <Panel title={o.providerSplit} desc={o.providerSplitDesc.replace('{rounds}', intComma(rounds))}>
      <ProviderDonut claude={claude} codex={codex} stepsLabel={locale === 'zh' ? '步骤' : 'STEPS'} />
    </Panel>
    <Panel title={o.collectionWindow} desc={o.collectionWindowDesc}>
      <div class="range-strip" style="margin-top:6px;">
        <span class="ico" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" style="stroke:var(--sage)" stroke-width="1.7" stroke-linecap="round"><rect x="3" y="4" width="18" height="17" rx="3"></rect><path d="M3 9h18M8 2v4M16 2v4"></path></svg>
        </span>
        <div>
          <div class="rt">{o.dateRange}</div>
          <div class="rv">{range}</div>
        </div>
      </div>
      <div style="margin-top:18px;">
        <svg viewBox="0 0 360 70" width="100%" height="70" preserveAspectRatio="none" role="img" aria-label={o.collectionVolumeLabel}>
          <defs><linearGradient id="tlg" x1="0" y1="0" x2="0" y2="1"><stop offset="0" style="stop-color:var(--terra)" stop-opacity="0.28"></stop><stop offset="1" style="stop-color:var(--terra)" stop-opacity="0"></stop></linearGradient></defs>
          <path d="M0,58 C40,52 60,44 90,40 C130,34 150,24 190,26 C230,28 250,16 290,14 C320,12 340,18 360,12 L360,70 L0,70 Z" fill="url(#tlg)"></path>
          <path d="M0,58 C40,52 60,44 90,40 C130,34 150,24 190,26 C230,28 250,16 290,14 C320,12 340,18 360,12" fill="none" style="stroke:var(--terra)" stroke-width="2.4" stroke-linecap="round"></path>
        </svg>
      </div>
    </Panel>
  </Band>

  <div class="sec-head reveal" style="--d:420ms">
    <h2>{o.galleryTitle}</h2>
  </div>

  <div class="gallery-sections" aria-label={o.galleryLabel}>
    {overviewFigureSections.map((section, sectionIndex) => (
      <section class="gallery-section reveal" style={`--d:${450 + sectionIndex * 60}ms`} aria-labelledby={`gallery-section-${section.key}`}>
        <div class="gallery-section-head">
          <div>
            <span class="gallery-section-type">{o.galleryType}</span>
            <h3 id={`gallery-section-${section.key}`}>{localizedSection(section).title}</h3>
          </div>
          <p>{localizedSection(section).description}</p>
        </div>
        <div class="gallery">
          {section.figures.map((fig) => {
            const card = localizedCard(fig.title, fig.blurb);
            const displayCategoryKey = gallerySectionKey(fig.category);
            return (
            <GalleryCard
              category={displayCategoryKey}
              displayCategory={fcopy.categories[displayCategoryKey as keyof typeof fcopy.categories] ?? displayCategoryKey}
              title={card.title}
              blurb={card.blurb}
              variant={fig.variant}
              src={fig.src}
              slug={fig.slug}
              statLines={fig.stat ? statMap[fig.stat] : headlinesFor(fig.slug)}
              readMore={fcopy.readMore}
              delay={nextGalleryDelay()}
            />
            );
          })}
        </div>
      </section>
    ))}
  </div>

  <Footer left={o.footer} />
</section>
