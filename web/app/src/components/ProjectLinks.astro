---
// External project links (GitHub · Paper · Blog · X). Rendered as icon+label chips.
// Two layouts via `variant`: 'column' (stacked, e.g. beside the hero) or 'strip' (inline row).
// Edit the URLs in one place below. `paper` is a static asset served from public/ — drop the
// PDF at web/app/public/paper.pdf and it downloads from /paper.pdf.
import { useTranslations } from '../i18n';

interface Props {
  variant?: 'column' | 'strip';
  class?: string;
  style?: string;
}
const { variant = 'column', class: cls = '', style } = Astro.props;
const t = useTranslations(Astro.url).topbar;

const url = {
  github: 'https://github.com/uw-syfi/TraceLab',
  paper: '/paper.pdf',
  blog: '#', // TODO: blog post URL
  twitter: '#', // TODO: x.com/<handle> URL
};

const ICONS: Record<string, string> = {
  github:
    '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>',
  paper:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M9 13h6M9 17h6M9 9h1"/></svg>',
  blog:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4z"/></svg>',
  twitter:
    '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>',
};

const items = [
  { key: 'github', href: url.github, label: t.github, external: true },
  { key: 'paper', href: url.paper, label: t.paper, download: true },
  { key: 'blog', href: url.blog, label: t.blog, external: true },
  { key: 'twitter', href: url.twitter, label: t.twitter, external: true },
];
---

<nav class:list={['proj-links', variant === 'column' ? 'col' : 'strip', cls]} style={style} aria-label={t.links}>
  {items.map((it) => (
    <a
      href={it.href}
      aria-label={it.label}
      title={it.label}
      {...(it.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
      {...(it.download ? { download: true } : {})}
    >
      <span class="pl-ico" set:html={ICONS[it.key]} />
      <span class="pl-label">{it.label}</span>
    </a>
  ))}
</nav>
