          "content": "#!/usr/bin/env python3\n\"\"\"Estimate how many tokens (KV-cache) fit on each GPU type, per model.\n\nFor each (model, GPU) we compute:\n\n    usable_mem   = vram * utilization          # leave headroom for CUDA ctx / fragmentation\n    kv_budget    = usable_mem - weight_mem      # memory left after loading model weights\n    max_tokens   = kv_budget / kv_bytes_per_token\n\n\"max tokens\" is the total number of tokens that can live in the KV cache at\nonce -- i.e. summed across all concurrent sequences (batch * seq_len).\n\nAll assumptions are explicit constants below so you can tweak them.\n\"\"\"\n\nfrom dataclasses import dataclass\n\n# Bytes per element for a given dtype name.\nDTYPE_BYTES = {\"fp32\": 4, \"fp16\": 2, \"bf16\": 2, \"fp8\": 1, \"int8\": 1, \"int4\": 0.5}\n\n# --------------------------------------------------------------------------- #\n# Tunable assumptions\n# --------------------------------------------------------------------------- #\nWEIGHT_DTYPE = \"fp16\"     # precision the weights are loaded in\nKV_DTYPE = \"fp16\"         # precision of the KV cache\nUTILIZATION = 0.90        # fraction of VRAM usable (vLLM-style gpu_memory_utilization)\nGIB = 1024 ** 3           # treat quoted VRAM as binary GiB\n\n\n# --------------------------------------------------------------------------- #\n# Model catalog\n# --------------------------------------------------------------------------- #\n@dataclass\nclass Model:\n    name: str\n    num_layers: int\n    num_kv_heads: int     # KV heads (GQA): drives KV-cache size\n    head_dim: int\n    num_params: float     # total parameter count\n\n    def kv_bytes_per_token(self, kv_dtype: str) -> float:\n        \"\"\"KV-cache bytes for a single token across all layers (K and V).\"\"\"\n        return 2 * self.num_layers * self.num_kv_heads * self.head_dim * DTYPE_BYTES[kv_dtype]\n\n    def weight_bytes(self, weight_dtype: str) -> float:\n        return self.num_params * DTYPE_BYTES[weight_dtype]\n\n\nMODELS = [\n    # name           layers  kv_heads  head_dim  params\n    Model(\"Llama3-8B\",   32,        8,      128,  8.03e9),\n    Model(\"Qwen3-32B\",   64,        8,      128, 32.8e9),\n]\n\n\n# --------------------------------------------------------------------------- #\n# GPU catalog: (name, VRAM in GB)\n# --------------------------------------------------------------------------- #\n@dataclass\nclass GPU:\n    name: str\n    vram_gb: int\n\nGPUS = [\n    GPU(\"V100-16GB\", 16),\n    GPU(\"V100-32GB\", 32),\n    GPU(\"A10-24GB\", 24),\n    GPU(\"L40S-48GB\", 48),\n    GPU(\"A100-40GB\", 40),\n    GPU(\"A100-80GB\", 80),\n    GPU(\"H100-80GB\", 80),\n    GPU(\"H200-141GB\", 141),\n    GPU(\"B200-192GB\", 192),\n    GPU(\"B300-288GB\", 288),\n]\n\n\ndef report(model: Model) -> None:\n    kv_per_tok = model.kv_bytes_per_token(KV_DTYPE)\n    w_bytes = model.weight_bytes(WEIGHT_DTYPE)\n\n    print(f\"== {model.name} ==  weights={WEIGHT_DTYPE} ({w_bytes / GIB:.1f} GiB)  \"\n          f\"|  KV={KV_DTYPE} ({kv_per_tok / 1024:.0f} KiB/token)  \"\n          f\"|  utilization={UTILIZATION:.0%}\")\n\n    header = f\"{'GPU':<14}{'VRAM':>7}{'KV budget':>12}{'Max tokens':>14}{'~ @8k ctx':>11}\"\n    print(header)\n    print(\"-\" * len(header))\n\n    for gpu in GPUS:\n        usable = gpu.vram_gb * GIB * UTILIZATION\n        kv_budget = usable - w_bytes\n        if kv_budget <= 0:\n            print(f\"{gpu.name:<14}{gpu.vram_gb:>5}GB{'OOM (weights do not fit)':>37}\")\n            continue\n        max_tokens = kv_budget / kv_per_tok\n        seqs_8k = max_tokens / 8192\n        print(f\"{gpu.name:<14}{gpu.vram_gb:>5}GB{kv_budget / GIB:>10.1f}GiB\"\n              f\"{max_tokens:>14,.0f}{seqs_8k:>11.1f}\")\n    print()\n\n\ndef main() -> None:\n    for model in MODELS:\n        report(model)\n\n\nif __name__ == \"__main__\":\n    main()\n"
