------------------------ #\n# Llama3-8B architecture (same for Llama-3 and Llama-3.1 8B)\n# --------------------------------------------------------------------------- #\nNUM_LAYERS = 32\nNUM_KV_HEADS = 8          # GQA: 8 KV heads (vs 32 query heads)\nHEAD_DIM = 128\nNUM_PARAMS = 8.03e9       # ~8.03 B parameters\n\n# Bytes per element for a given dtype name.\nDTYPE_BYTES = {\"fp32\": 4, \"fp16\": 2, \"bf16\": 2, \"fp8\": 1, \"int8\": 1, \"int4\": 0.5}\n\n# --------------------------------------------------------------------------- #\n# Tunable assumptions\n# --------------------------------------------------------------------------- #\nWEIGHT_DTYPE = \"fp16\"     # precision the weights are loaded in\nKV_DTYPE = \"fp16\"         # precision of the KV cache\nUTILIZATION = 0.90        # fraction of VRAM usable (vLLM-style gpu_memory_utilization)\nGIB = 1024 ** 3           # treat quoted VRAM as binary GiB\n\n# --------------------------------------------------------------------------- #\n# GPU catalog: (name, VRAM in GB)\n# --------------------------------------------------------------------------- #\n@dataclass\nclass GPU:\n    name: str\n    vram_gb: int\n\nGPUS = [\n    GPU(\"V100-16GB\", 16),\n    GPU(\"V100-32GB\", 32),\n    GPU(\"A10-24GB\", 24),\n    GPU(\"L40S-48GB\", 48),\n    GPU(\"A100-40GB\", 40),\n    GPU(\"A100-80GB\", 80),\n    GPU(\"H100-80GB\", 80),\n    GPU(\"H200-141GB\", 141),\n    GPU(\"B200-192GB\", 192),\n    GPU(\"B300-288GB\", 288),\n]\n\n\ndef kv_bytes_per_token(kv_dtype: str) -> int:\n    \"\"\"KV-cache bytes for a single token across all layers (K and V).\"\"\"\n    return 2 * NUM_LAYERS * NUM_KV_HEADS * HEAD_DIM * DTYPE_BYTES[kv_dtype]\n\n\ndef weight_bytes(weight_dtype: str) -> float:\n    return NUM_PARAMS * DTYPE_BYTES[weight_dtype]\n\n\ndef main() -> None:\n    kv_per_tok = kv_bytes_per_token(KV_DTYPE)\n    w_bytes = weight_bytes(WEIGHT_DTYPE)\n\n    print(f\"Model: Llama3-8B  |  weights={WEIGHT_DTYPE} ({w_bytes / GIB:.1f} GiB)  \"\n          f\"|  KV={KV_DTYPE} ({kv_per_tok / 1024:.0f} KiB/token)  \"\n          f\"|  utilization={UTILIZATION:.0%}\\n\")\n\n    header = f\"{'GPU':<14}{'VRAM':>7}{'KV budget':>12}{'Max tokens':>14}{'~ @8k ctx':>11}\"\n    print(header)\n    print(\"-\" * len(header))\n\n    for gpu in GPUS:\n        usable = gpu.vram_gb * GIB * UTILIZATION\n        kv_budget = usable - w_bytes\n        if kv_budget <= 0:\n            print(f\"{gpu.name:<14}{gpu.vram_gb:>5}GB{'--':>12}{'OOM (weights do not fit)':>25}\")\n            continue\n        max_tokens = kv_budget / kv_per_tok\n        seqs_8k = max_tokens / 8192\n        print(f\"{gpu.name:<14}{gpu.vram_gb:>5}GB{kv_budget / GIB:>10.1f}GiB\"\n              f\"{max_tokens:>14,.0f}{seqs_8k:>11.1f}\")\n\n\nif __name__ == \"__main__\":\n    main()\n"},"input_chars":3557,"result_chars":136,"tool_wall_latency_ms":21467,"tool_internal_latency_ms":null,"is_error":false,"result_at":"2026-06-01T05:42:05.482Z"}],"current_input_event_count":1,"current_user_message_count":0,"current_tool_result_count":1,"current_user_message_chars":0,"current_tool_result_chars":4157,"current_input_chars":4157,"first_input_event_type":"tool_result","home":"/home/user","user":"user","store":".claude","trace_key":"claude:claude:claude-public-example:msg_01aab3d849970e554b86dcec"}
